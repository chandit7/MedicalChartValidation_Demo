# Medical Chart Validation System - Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# GROQ API CONFIGURATION (Optional - for AI Analytics features)
# =============================================================================
# Get your FREE API key from: https://console.groq.com
# - No credit card required
# - 6000 requests/minute free tier
# - Llama 3.3 70B model access
#
# Note: The core validation system works WITHOUT this key.
# This is only needed for AI-powered analytics in Tab 4.
GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Path to SQLite database file (inside container)
# Default: /app/data/medchart.db (persisted via volume mount)
DB_PATH=/app/data/medchart.db

# =============================================================================
# STREAMLIT CONFIGURATION
# =============================================================================
# Server settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# Theme settings (optional)
# STREAMLIT_THEME_BASE=light
# STREAMLIT_THEME_PRIMARY_COLOR=#4CAF50
# STREAMLIT_THEME_BACKGROUND_COLOR=#FFFFFF
# STREAMLIT_THEME_SECONDARY_BACKGROUND_COLOR=#F0F2F6

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Maximum file upload size (in MB)
# STREAMLIT_SERVER_MAX_UPLOAD_SIZE=5

# Enable/disable file watcher (set to false in production)
# STREAMLIT_SERVER_FILE_WATCHER_TYPE=none

# =============================================================================
# DOCKER-SPECIFIC SETTINGS
# =============================================================================
# These are automatically set by docker-compose.yml
# Uncomment to override

# Container timezone
# TZ=UTC

# Python settings
# PYTHONUNBUFFERED=1
# PYTHONDONTWRITEBYTECODE=1

# =============================================================================
# PRODUCTION SETTINGS (for docker-compose.prod.yml)
# =============================================================================
# Uncomment for production deployment

# Enable HTTPS
# STREAMLIT_SERVER_ENABLE_CORS=false
# STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION=true

# Resource limits
# STREAMLIT_SERVER_MAX_MESSAGE_SIZE=200

# Logging
# STREAMLIT_LOGGER_LEVEL=info